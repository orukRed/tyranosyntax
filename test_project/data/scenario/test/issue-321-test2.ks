; issue-321 未使用変数検出機能のテスト（クロスファイル検証用）
; issue-321-test.ks で定義された f.issue321_used_from_other_file を読み取る

; 別ファイルで定義された変数を cond で参照
; → issue-321-test.ks 側で警告が出ないことを確認
[if exp="f.issue321_used_from_other_file == 42"]
  [p]
[endif]

; ====================================================================
; このファイル内で定義され一度も読まれない変数（警告が出ること）
; ====================================================================
[eval exp="f.issue321_unused_in_test2 = 0"]

[s]
