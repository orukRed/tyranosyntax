; issue-324 未使用マクロ検出機能のテスト
; 未使用マクロは黄色の警告として検出される

*start

; ====================================================================
; ケース1: 使用されているマクロ（警告が出ないこと）
; このファイル内で[issue324_used]として呼び出される
; ====================================================================
[macro name="issue324_used"]
  使用されているマクロです。[p]
[endmacro]

; ====================================================================
; ケース2: どこからも呼び出されていないマクロ（警告が出ること）
; macro name="issue324_unused" の部分に黄色い波線が出るはず
; ====================================================================
[macro name="issue324_unused"]
  このマクロは使われていません。[p]
[endmacro]

; ====================================================================
; ケース3: 自己参照のみのマクロ（警告が出ること）
; マクロ定義ブロック内の呼び出しは「使用」にカウントされない
; ====================================================================
[macro name="issue324_self_only"]
  [issue324_self_only]
[endmacro]

; ====================================================================
; ケース4: 別ファイル (issue-324-test2.ks) から呼ばれるマクロ（警告が出ないこと）
; ====================================================================
[macro name="issue324_used_from_other_file"]
  別ファイルから呼び出されるマクロです。[p]
[endmacro]

; ====================================================================
; ケース5: 重複 + 未使用（両方の警告が表示されること）
; issue324_duplicate はこのファイルと issue-324-test2.ks の両方で定義され、
; さらにどこからも呼ばれないため、各定義箇所に
;   - マクロ重複 (Warning)
;   - 未使用マクロ (Warning)
; の 2 種類の警告が同時に出るはず
; ====================================================================
[macro name="issue324_duplicate"]
  重複かつ未使用のマクロです。[p]
[endmacro]

; --------------------------------------------------------------------
; マクロ呼び出し
; --------------------------------------------------------------------
[issue324_used]

[s]
