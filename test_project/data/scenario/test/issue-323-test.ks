; issue-323 未使用ラベル検出機能のテスト
; 未使用ラベルは黄色の警告として検出される

*start

; ====================================================================
; ケース1: 同一ファイル内で jump から参照されているラベル（警告が出ないこと）
; ====================================================================
  [jump target="*issue323_jumped_from_self"]

*issue323_jumped_from_self

; ====================================================================
; ケース2: 同一ファイル内で call から参照されているラベル（警告が出ないこと）
; ====================================================================
  [call target="*issue323_called_from_self"]

*issue323_called_from_self

; ====================================================================
; ケース3: 同一ファイル内で button から参照されているラベル（警告が出ないこと）
; ====================================================================
  [button name="btn" target="*issue323_button_target_self" graphic="btn.png"]

*issue323_button_target_self

; ====================================================================
; ケース4: どこからも参照されていないラベル（警告が出ること）
; *issue323_unused の行に黄色い波線が出るはず
; ====================================================================
*issue323_unused

; ====================================================================
; ケース5: 別ファイル (issue-323-test2.ks) から参照されているラベル（警告が出ないこと）
; issue-323-test2.ks 側で [jump storage="test/issue-323-test.ks" target="*issue323_used_from_other_file"] される
; ====================================================================
*issue323_used_from_other_file

; ====================================================================
; ケース6: 変数参照（&付き）は解決不能のため、解決不能な参照としてスキップされる
; この結果、*issue323_target_by_var は参照されていないとみなされ警告が出る
; ====================================================================
*issue323_target_by_var

  [jump target="&f.someLabel"]

; ====================================================================
; ケース7: link タグから参照されているラベル（警告が出ないこと）
; ====================================================================
  [link target="*issue323_link_target_self"]テスト[endlink]

*issue323_link_target_self

[s]
