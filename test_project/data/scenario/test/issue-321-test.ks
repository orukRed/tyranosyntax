; issue-321 未使用変数検出機能のテスト
; 未使用変数は黄色の警告として検出される

*start

; ====================================================================
; ケース1: exp で参照されている変数（警告が出ないこと）
; f.issue321_used_in_exp は f.issue321_dummy_lhs の RHS で読まれる
; ====================================================================
[eval exp="f.issue321_used_in_exp = 10"]
[eval exp="f.issue321_dummy_lhs = f.issue321_used_in_exp + 1"]

; ====================================================================
; ケース2: cond で参照されている変数（警告が出ないこと）
; ====================================================================
[eval exp="f.issue321_used_in_cond = 1"]
[if exp="f.issue321_used_in_cond == 1"]
  [p]
[endif]

; ====================================================================
; ケース3: テキスト中の埋め込み参照（&f.xxx;）で読まれる変数（警告が出ないこと）
; ====================================================================
[eval exp="f.issue321_used_in_text = 0"]
こんにちは [emb exp="f.issue321_used_in_text" ]  さん[p]

; ====================================================================
; ケース4: どこからも読まれない変数（警告が出ること）
; [eval exp="f.issue321_unused_plain = 100"] の行に黄色い波線が出るはず
; ====================================================================
[eval exp="f.issue321_unused_plain = 100"]

; ====================================================================
; ケース5: 複合代入 (+=) のみ。複合代入は左辺も読み取り扱いとし、
; このケースでは警告が出ないこと
; ====================================================================
[eval exp="f.issue321_compound_used = 0"]
[eval exp="f.issue321_compound_used += 1"]

; ====================================================================
; ケース6: 自己参照 (f.x = f.x + 1)。RHS の自己参照を「読み取り」と扱うため
; 警告が出ないこと
; ====================================================================
[eval exp="f.issue321_self_ref = 0"]
[eval exp="f.issue321_self_ref = f.issue321_self_ref + 1"]

; ====================================================================
; ケース7: iscript 内の変数の取り扱い
; - f.issue321_used_in_iscript は eval で定義され iscript 内で読まれる（警告なし）
; - f.issue321_unused_in_iscript は iscript 内でのみ代入され他で読まれない
;   → iscript 内代入も定義として扱い、未使用なら警告を出す
; ====================================================================
[eval exp="f.issue321_used_in_iscript = 0"]
[iscript]
if (f.issue321_used_in_iscript > 0) {
  f.issue321_unused_in_iscript = 0;  
}
[endscript]

; ====================================================================
; ケース8: 別ファイル (issue-321-test2.ks) から参照されている変数（警告が出ないこと）
; issue-321-test2.ks 側で f.issue321_used_from_other_file が読まれる
; ====================================================================
[eval exp="f.issue321_used_from_other_file = 42"]

; ====================================================================
; ケース9: sf / tf 名前空間でも未使用なら警告が出ること
; ====================================================================
[eval exp="sf.issue321_unused_sf = 1"]
[eval exp="tf.issue321_unused_tf = 1"]

[s]
