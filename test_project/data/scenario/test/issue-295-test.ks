; issue-295 callタグ・fixボタンの呼び出し先にreturnタグが無い場合の警告テスト
; 呼び出し先ファイルに [return] が無い場合、storage パラメータに警告が出る
;
; このファイルでは、呼び出し先ファイル ↓ を切り替えて検証する
;   - test/issue-295-test-with-return.ks    : [return] あり (警告が出ないこと)
;   - test/issue-295-test-without-return.ks : [return] なし (警告が出ること)

*start

; ====================================================================
; ケース1: callタグで [return] のあるファイルを呼ぶ（警告が出ないこと）
; ====================================================================
[call storage="test/issue-295-test-with-return.ks"]

; ====================================================================
; ケース2: callタグで [return] のないファイルを呼ぶ（警告が出ること）
; → storage の "test/issue-295-test-without-return.ks" に黄色い波線が出るはず
; ====================================================================
[call storage="test/issue-295-test-without-return.ks"]

; ====================================================================
; ケース3: fix="true" のbuttonで [return] のないファイルを呼ぶ（警告が出ること）
; → storage の "test/issue-295-test-without-return.ks" に黄色い波線が出るはず
; ====================================================================
[button graphic="btn.png" fix="true" storage="test/issue-295-test-without-return.ks" target="*sub"]

; ====================================================================
; ケース4: fix="false" のbuttonで [return] のないファイルを呼ぶ（警告が出ないこと）
; fix=false のボタンはコールスタックを残さないため、対象外
; ====================================================================
[button graphic="btn.png" fix="false" storage="test/issue-295-test-without-return.ks" target="*sub"]

; ====================================================================
; ケース5: jumpタグは呼び出し（コールスタック）ではないため、対象外（警告が出ないこと）
; ====================================================================
[jump storage="test/issue-295-test-without-return.ks"]

; ====================================================================
; ケース6: storageが変数を含む場合は静的解析できないためスキップ（警告が出ないこと）
; ====================================================================
[eval exp="f.issue295_target = 'test/issue-295-test-without-return.ks'"]
[call storage="&f.issue295_target"]

; ====================================================================
; ケース7: role が指定されたfixボタンは特殊機能用のためスキップ（警告が出ないこと）
; ====================================================================
[button graphic="btn.png" fix="true" role="save" storage="test/issue-295-test-without-return.ks"]

[s]
